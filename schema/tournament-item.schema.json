{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "tournament",
  "title": "SBR Tournament Results",
  "description": "Combined tournament results with team placements, player info, and reward codes",
  "type": "object",
  "required": ["id", "url", "date", "teams"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Tournament identifier"
    },
    "url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Tournament website URL"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Tournament start date (ISO 8601, e.g. 2025-04-01)"
    },
    "teams": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "tag", "placement", "players"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable team name"
          },
          "tag": {
            "type": "string",
            "description": "In-game clan tag including brackets, e.g. [PU5H]"
          },
          "placement": {
            "type": "integer",
            "minimum": 1,
            "description": "Final tournament placement (1 = winner)"
          },
          "players": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["handle", "battletag", "name"],
              "properties": {
                "handle": {
                  "type": "string",
                  "pattern": "^\\d+-S2-\\d+-\\d+$",
                  "description": "StarCraft II account handle"
                },
                "battletag": {
                  "type": "string",
                  "pattern": "^.+#\\d+$",
                  "description": "Battle.net BattleTag"
                },
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "description": "In-game display name (without clan tag prefix)"
                },
                "rewards": {
                  "type": "array",
                  "minItems": 0,
                  "items": {
                    "type": "string",
                    "enum": [
                      "T1",
                      "T2",
                      "T3",
                      "T4",
                      "T5",
                      "TF0",
                      "TF1",
                      "TF2",
                      "TF3",
                      "TF4",
                      "TF5",
                      "TF6",
                      "TF7",
                      "TF8",
                      "TF9",
                      "TF10",
                      "TF11",
                      "TF12",
                      "TF13",
                      "TF14",
                      "TF15",
                      "TF16",
                      "TF17",
                      "TF18",
                      "TF19",
                      "TF20",
                      "TF21",
                      "TF22"
                    ],
                    "description": "T[1-5] = legacy stars (1-4 = top4, 5th = participated); TF[XX] = Tournament Finals (0 / 1 flag = special skin / unlock)",
                    "uniqueItems": true
                  },
                  "description": "Reward codes earned in this tournament"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
